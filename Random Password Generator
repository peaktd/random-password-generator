import tkinter as tk
from tkinter import ttk, messagebox
import random
import string
import json
import os
from datetime import datetime

class PasswordGeneratorApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Random Password Generator")
        self.root.geometry("800x600")
        self.root.resizable(True, True)
        
        # Путь к файлу истории
        self.history_file = "password_history.json"
        
        # Загружаем историю
        self.history = self.load_history()
        
        # Создаем интерфейс
        self.create_widgets()
        
        # Генерируем пароль при запуске
        self.generate_password()
    
    def create_widgets(self):
        # Основной фрейм
        main_frame = ttk.Frame(self.root, padding="10")
        main_frame.grid(row=0, column=0, sticky=(tk.W, tk.E, tk.N, tk.S))
        
        # Настройка весов для растягивания
        self.root.columnconfigure(0, weight=1)
        self.root.rowconfigure(0, weight=1)
        main_frame.columnconfigure(0, weight=1)
        main_frame.rowconfigure(4, weight=1)
        
        # Заголовок
        title_label = ttk.Label(main_frame, text="Генератор случайных паролей", 
                                font=("Arial", 16, "bold"))
        title_label.grid(row=0, column=0, pady=10)
        
        # === 1. Ползунок длины пароля ===
        length_frame = ttk.LabelFrame(main_frame, text="Длина пароля", padding="10")
        length_frame.grid(row=1, column=0, sticky=(tk.W, tk.E), pady=5)
        length_frame.columnconfigure(1, weight=1)
        
        ttk.Label(length_frame, text="Длина:").grid(row=0, column=0, padx=5)
        
        self.password_length = tk.IntVar(value=12)
        self.length_scale = ttk.Scale(
            length_frame, 
            from_=4, 
            to=32, 
            orient=tk.HORIZONTAL,
            variable=self.password_length,
            command=self.update_length_label
        )
        self.length_scale.grid(row=0, column=1, sticky=(tk.W, tk.E), padx=5)
        
        self.length_label = ttk.Label(length_frame, text="12", width=5)
        self.length_label.grid(row=0, column=2, padx=5)
        
        # Минимальная и максимальная длина
        ttk.Label(length_frame, text="Мин: 4").grid(row=1, column=0, padx=5, pady=2)
        ttk.Label(length_frame, text="Макс: 32").grid(row=1, column=2, padx=5, pady=2)
        
        # === 2. Чекбоксы для выбора символов ===
        chars_frame = ttk.LabelFrame(main_frame, text="Типы символов", padding="10")
        chars_frame.grid(row=2, column=0, sticky=(tk.W, tk.E), pady=5)
        
        self.use_lowercase = tk.BooleanVar(value=True)
        self.use_uppercase = tk.BooleanVar(value=True)
        self.use_digits = tk.BooleanVar(value=True)
        self.use_special = tk.BooleanVar(value=False)
        
        ttk.Checkbutton(chars_frame, text="Строчные буквы (a-z)", 
                       variable=self.use_lowercase).grid(row=0, column=0, sticky=tk.W, padx=10)
        ttk.Checkbutton(chars_frame, text="Заглавные буквы (A-Z)", 
                       variable=self.use_uppercase).grid(row=0, column=1, sticky=tk.W, padx=10)
        ttk.Checkbutton(chars_frame, text="Цифры (0-9)", 
                       variable=self.use_digits).grid(row=1, column=0, sticky=tk.W, padx=10)
        ttk.Checkbutton(chars_frame, text="Спецсимволы (!@#$%^&*)", 
                       variable=self.use_special).grid(row=1, column=1, sticky=tk.W, padx=10)
        
        # === 3. Кнопка генерации ===
        button_frame = ttk.Frame(main_frame)
        button_frame.grid(row=3, column=0, pady=10)
        
        self.generate_btn = ttk.Button(button_frame, text="Сгенерировать пароль", 
                                       command=self.generate_password)
        self.generate_btn.pack(side=tk.LEFT, padx=5)
        
        self.copy_btn = ttk.Button(button_frame, text="Копировать в буфер", 
                                   command=self.copy_to_clipboard)
        self.copy_btn.pack(side=tk.LEFT, padx=5)
        
        # Поле для отображения сгенерированного пароля
        self.password_display = tk.Text(main_frame, height=3, font=("Courier", 12))
        self.password_display.grid(row=4, column=0, sticky=(tk.W, tk.E), pady=10)
        
        # === 4. Таблица истории ===
        history_frame = ttk.LabelFrame(main_frame, text="История паролей", padding="10")
        history_frame.grid(row=5, column=0, sticky=(tk.W, tk.E, tk.N, tk.S), pady=10)
        history_frame.columnconfigure(0, weight=1)
        history_frame.rowconfigure(0, weight=1)
        
        # Создаем Treeview для истории
        columns = ("timestamp", "password", "length", "types")
        self.history_tree = ttk.Treeview(history_frame, columns=columns, show="headings")
        
        # Настройка заголовков
        self.history_tree.heading("timestamp", text="Дата и время")
        self.history_tree.heading("password", text="Пароль")
        self.history_tree.heading("length", text="Длина")
        self.history_tree.heading("types", text="Типы символов")
        
        # Настройка ширины колонок
        self.history_tree.column("timestamp", width=150)
        self.history_tree.column("password", width=300)
        self.history_tree.column("length", width=60)
        self.history_tree.column("types", width=150)
        
        # Добавляем скроллбар
        scrollbar = ttk.Scrollbar(history_frame, orient=tk.VERTICAL, 
                                  command=self.history_tree.yview)
        self.history_tree.configure(yscrollcommand=scrollbar.set)
        
        self.history_tree.grid(row=0, column=0, sticky=(tk.W, tk.E, tk.N, tk.S))
        scrollbar.grid(row=0, column=1, sticky=(tk.N, tk.S))
        
        # Кнопки для управления историей
        history_buttons_frame = ttk.Frame(history_frame)
        history_buttons_frame.grid(row=1, column=0, columnspan=2, pady=5)
        
        ttk.Button(history_buttons_frame, text="Очистить историю", 
                  command=self.clear_history).pack(side=tk.LEFT, padx=5)
        ttk.Button(history_buttons_frame, text="Обновить историю", 
                  command=self.refresh_history_display).pack(side=tk.LEFT, padx=5)
        
        # Обновляем отображение истории
        self.refresh_history_display()
    
    def update_length_label(self, value):
        """Обновляет метку с текущей длиной пароля"""
        length = int(float(value))
        self.length_label.config(text=str(length))
    
    def get_character_set(self):
        """Возвращает набор символов на основе выбранных опций"""
        chars = ""
        
        if self.use_lowercase.get():
            chars += string.ascii_lowercase
        if self.use_uppercase.get():
            chars += string.ascii_uppercase
        if self.use_digits.get():
            chars += string.digits
        if self.use_special.get():
            chars += "!@#$%^&*()_+-=[]{}|;:,.<>?"
        
        return chars
    
    def validate_options(self):
        """Проверяет корректность выбранных опций"""
        chars = self.get_character_set()
        
        if not chars:
            messagebox.showerror("Ошибка", "Выберите хотя бы один тип символов!")
            return False
        
        length = self.password_length.get()
        
        if length < 4:
            messagebox.showerror("Ошибка", "Длина пароля не может быть меньше 4 символов!")
            return False
        
        if length > 32:
            messagebox.showerror("Ошибка", "Длина пароля не может быть больше 32 символов!")
            return False
        
        if length > len(chars) and len(chars) > 0:
            # Если длина больше доступных уникальных символов, все равно можно генерировать
            # с повторениями, так что это не критично
            pass
        
        return True
    
    def generate_password(self):
        """Генерирует случайный пароль"""
        if not self.validate_options():
            return
        
        length = self.password_length.get()
        chars = self.get_character_set()
        
        # Генерация пароля
        password = []
        for _ in range(length):
            password.append(random.choice(chars))
        
        # Перемешиваем для дополнительной случайности
        random.shuffle(password)
        generated_password = ''.join(password)
        
        # Отображаем пароль
        self.password_display.delete(1.0, tk.END)
        self.password_display.insert(1.0, generated_password)
        
        # Сохраняем в историю
        self.save_to_history(generated_password, length)
    
    def save_to_history(self, password, length):
        """Сохраняет сгенерированный пароль в историю"""
        # Определяем использованные типы символов
        types_used = []
        if self.use_lowercase.get():
            types_used.append("строчные")
        if self.use_uppercase.get():
            types_used.append("заглавные")
        if self.use_digits.get():
            types_used.append("цифры")
        if self.use_special.get():
            types_used.append("спецсимволы")
        
        types_str = ", ".join(types_used)
        
        # Создаем запись
        record = {
            "timestamp": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            "password": password,
            "length": length,
            "types": types_str
        }
        
        # Добавляем в начало списка (новые сверху)
        self.history.insert(0, record)
        
        # Ограничиваем историю последними 50 записями
        if len(self.history) > 50:
            self.history = self.history[:50]
        
        # Сохраняем в файл
        self.save_history()
        
        # Обновляем отображение
        self.refresh_history_display()
    
    def load_history(self):
        """Загружает историю из JSON файла"""
        if os.path.exists(self.history_file):
            try:
                with open(self.history_file, 'r', encoding='utf-8') as f:
                    return json.load(f)
            except (json.JSONDecodeError, IOError):
                return []
        return []
    
    def save_history(self):
        """Сохраняет историю в JSON файл"""
        try:
            with open(self.history_file, 'w', encoding='utf-8') as f:
                json.dump(self.history, f, ensure_ascii=False, indent=2)
        except IOError as e:
            messagebox.showerror("Ошибка", f"Не удалось сохранить историю: {e}")
    
    def refresh_history_display(self):
        """Обновляет отображение истории"""
        # Очищаем текущее отображение
        for item in self.history_tree.get_children():
            self.history_tree.delete(item)
        
        # Добавляем записи из истории
        for record in self.history:
            self.history_tree.insert("", "end", values=(
                record["timestamp"],
                record["password"],
                record["length"],
                record["types"]
            ))
    
    def clear_history(self):
        """Очищает историю"""
        if messagebox.askyesno("Подтверждение", "Вы уверены, что хотите очистить всю историю?"):
            self.history = []
            self.save_history()
            self.refresh_history_display()
            messagebox.showinfo("Успех", "История очищена")
    
    def copy_to_clipboard(self):
        """Копирует сгенерированный пароль в буфер обмена"""
        password = self.password_display.get(1.0, tk.END).strip()
        if password:
            self.root.clipboard_clear()
            self.root.clipboard_append(password)
            messagebox.showinfo("Успех", "Пароль скопирован в буфер обмена")
        else:
            messagebox.showwarning("Предупреждение", "Нет сгенерированного пароля для копирования")

def main():
    root = tk.Tk()
    app = PasswordGeneratorApp(root)
    root.mainloop()

if __name__ == "__main__":
    main()
